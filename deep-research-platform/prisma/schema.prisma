generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String            @id @default(cuid())
  email       String?           @unique
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  projects    Project[]
  sessions    ResearchSession[]
  apiKeys     UserApiKey[]
  usageEvents UsageEvent[]
  firebaseUid String?           @unique
}

model Project {
  id          String            @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions    ResearchSession[]
}

model ResearchSession {
  id                  String         @id @default(cuid())
  topic               String
  audience            String?
  depthLevel          String         @default("standard")
  citationStyle       String         @default("apa")
  sourceCount         Int            @default(20)
  dateRangeStart      Int?
  dateRangeEnd        Int?
  domainRestrictions  String[]       @default([])
  excludedSourceTypes String[]       @default([])
  status              ResearchStatus @default(created)
  plan                Json?
  candidateSources    Json?
  rankedSources       Json?
  verifiedCitations   Json?
  finalReport         String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  userId              String
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId           String?
  project             Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  logs                ResearchLog[]
  artifacts           ResearchArtifact[]

  @@index([userId])
  @@index([projectId])
}

enum ResearchStatus {
  created
  planning
  searching
  retrieving
  indexing
  ranking
  verifying
  synthesizing
  complete
  failed
}

model ResearchLog {
  id        String          @id @default(cuid())
  sessionId String
  session   ResearchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  phase     String
  message   String
  metadata  Json?
  createdAt DateTime        @default(now())

  @@index([sessionId])
}

model ResearchArtifact {
  id        String          @id @default(cuid())
  sessionId String
  session   ResearchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type      String
  format    String
  content   String
  createdAt DateTime        @default(now())

  @@index([sessionId])
}

model UserApiKey {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String
  encryptedKey String
  modelId      String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime?

  @@index([userId])
}

model Document {
  id         String          @id @default(cuid())
  title      String
  sourceUrl  String?
  sourceType String
  content    String?
  metadata   Json?
  createdAt  DateTime        @default(now())
  chunks     DocumentChunk[]
}

model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content    String
  embedding  Unsupported("vector(1536)")?
  index      Int
}

model UsageEvent {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId        String?
  eventType        String
  provider         String?
  model            String?
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  costUsd          Float?
  metadata         Json?
  createdAt        DateTime @default(now())

  @@index([userId])
}
